<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Current_Value_Not_Negative</fullName>
    <active>true</active>
    <errorConditionFormula>Current_Value__c &lt; 0</errorConditionFormula>
    <errorDisplayField>Current_Value__c</errorDisplayField>
    <errorMessage>Current Value cannot be negative</errorMessage>
</ValidationRule>
